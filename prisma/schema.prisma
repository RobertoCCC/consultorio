// Consultorio - schema da base de dados
// Modelo abstrato para suportar diferentes tipos de consultorio
// (clinica, advocacia, contabilidade) com a mesma estrutura.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// Enums
// =============================================================

enum UserRole {
  ADMIN
  STAFF
  DOCTOR
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

// =============================================================
// Auth / Staff
// =============================================================

// User = staff do consultorio (medico, rececionista, advogado, contabilista).
// Em producao multi-tenant seria associado a uma Organization; para o demo
// e single-tenant, todos os utilizadores partilham o mesmo deploy.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments Appointment[] @relation("StaffAppointments")
}

// =============================================================
// Domain
// =============================================================

// Patient = cliente do consultorio. Em advocacia/contabilidade
// renomeia-se "Cliente" na UI; estrutura permanece igual.
model Patient {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  birthDate DateTime?
  nif       String? // Numero de Identificacao Fiscal (PT)
  address   String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  appointments Appointment[]
  invoices     Invoice[]

  @@index([name])
}

// Service = catalogo de servicos prestados (consulta, exame, tratamento, etc.)
model Service {
  id              String   @id @default(cuid())
  name            String
  description     String?
  durationMinutes Int      @default(30)
  priceCents      Int      @default(0) // preco em centimos EUR
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments Appointment[]
  invoiceLines InvoiceLine[]
}

// Appointment = marcacao agendada (paciente + staff + servico + slot).
model Appointment {
  id              String            @id @default(cuid())
  startsAt        DateTime
  durationMinutes Int
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffId   String
  staff     User    @relation("StaffAppointments", fields: [staffId], references: [id])
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  invoiceLines InvoiceLine[]

  @@index([startsAt])
  @@index([patientId])
  @@index([staffId])
  @@index([status])
}

// =============================================================
// Billing
// =============================================================

// Invoice = fatura emitida (cabecalho). Linhas em InvoiceLine.
model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique // ex: "FT 2026/0001"
  issuedAt      DateTime      @default(now())
  dueDate       DateTime?
  status        InvoiceStatus @default(ISSUED)
  subtotalCents Int
  taxCents      Int           @default(0)
  totalCents    Int
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  lines InvoiceLine[]

  @@index([patientId])
  @@index([issuedAt])
  @@index([status])
}

model InvoiceLine {
  id             String @id @default(cuid())
  description    String
  quantity       Int    @default(1)
  unitPriceCents Int
  lineTotalCents Int

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([invoiceId])
}
