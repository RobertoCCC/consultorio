# =============================================================
# Consultorio - environment variables
# Copia este ficheiro para .env e preenche com valores reais.
# =============================================================

# Postgres (recomendado: Neon serverless)
# 1. Cria conta em https://console.neon.tech
# 2. Cria projeto "consultorio" na regiao Frankfurt
# 3. Copia a "Connection string" e cola aqui
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Auth.js
# Gera com: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"

# Em producao (Vercel), AUTH_URL e definido automaticamente.
# Em desenvolvimento local nao e necessario.
# AUTH_URL="http://localhost:3000"
